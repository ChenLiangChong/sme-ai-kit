# 資料庫
data/*.db
data/*.db-wal
data/*.db-shm

# 使用者資料
data/media/
data/*.log

# 密鑰
.mcp.json
.env
data/line-channels.json

# 打包產物
dist/

# docs/ 預設不追蹤、只 whitelist 通用內容
# （客戶資料、IG 素材、課程草稿、研究筆記、個人圖片等都在這裡）
docs/*
!docs/project-overview.html
!docs/skill-translation/
!docs/course/

# course/ 內預設不追蹤、只 whitelist lesson-01 舊版 3 檔
docs/course/*
!docs/course/lesson-01/
docs/course/lesson-01/*
!docs/course/lesson-01/lesson-01-flow.md
!docs/course/lesson-01/lesson-01-overview.html
!docs/course/lesson-01/lesson-01.md

# 執行環境
.venv/
node_modules/
__pycache__/
*.pyc
bun.lockb

# OS
.DS_Store
Thumbs.db

# FUSE 暫存檔（雲端掛載留下的）
data/.fuse_hidden*

# 個人業務資料（不上傳通用版）
data/import_*.sql
.claude/memory/
.claude/skills/*/node_modules/

# Codex CLI 本地快取（user-specific；保留 hooks.json / agents/*.toml 等 repo 設定）
.codex/sessions/
.codex/logs/
.codex/cache/
.codex/state*
.codex/history*
